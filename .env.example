# Copy this file to .env for local Docker Compose runs.
# Never commit the real .env file.

# Twitch app credentials and user tokens.
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here
TWITCH_ACCESS_TOKEN=your_access_token_here
TWITCH_REFRESH_TOKEN=your_refresh_token_here

# Live IRC still needs the Twitch login that owns the chat token.
TWITCH_USERNAME=your_twitch_login_here

# Compose-only convenience channel for `docker compose run --rm live`.
TWITCH_CHANNEL=somechannel

# Optional twi feature modes.
TWI_AVATAR_MODE=initials
TWI_ANIMATION_MODE=fast
